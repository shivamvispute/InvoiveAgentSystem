# ============================
# Invoice Agent System — Environment Configuration
# ============================

# --- LLM Provider (Groq is FREE) ---
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model choices (all free on Groq):
#   llama-3.3-70b-versatile   ← Recommended (best quality)
#   llama-3.1-8b-instant      ← Fastest
#   mixtral-8x7b-32768        ← Good for long documents
LLM_MODEL=llama-3.3-70b-versatile

# --- Database ---
# SQLite (no Docker needed) — file stored locally
DATABASE_URL=sqlite+aiosqlite:///./invoice_agent.db

# --- Redis (optional) ---
# Set USE_FAKE_REDIS=true to skip Redis entirely (no install needed)
USE_FAKE_REDIS=true
REDIS_URL=redis://localhost:6379

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- Agent Config ---
# Max retries for agent LLM calls
AGENT_MAX_RETRIES=3
# Anomaly detection sensitivity: low | medium | high
ANOMALY_SENSITIVITY=medium
# Auto-approve invoices below this amount (no human review needed)
AUTO_APPROVE_THRESHOLD=1000.00

# --- Observability ---
# Set to false to disable tracing (lighter weight for demo)
ENABLE_TRACING=true
OTLP_ENDPOINT=http://localhost:4317

# --- Demo Mode ---
# Generates synthetic invoices automatically
DEMO_MODE=true
